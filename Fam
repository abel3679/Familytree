<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Family Tree</title>
    <!-- Import the free family tree rendering engine -->
    <script src="https://balkan.app/js/familytree.js"></script>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #f4f6f9;
            overflow: hidden;
        }
        #header {
            background-color: #2c3e50;
            color: white;
            padding: 15px 20px;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            z-index: 10;
        }
        #header h1 { margin: 0; font-size: 24px; font-weight: 600; }
        #tree {
            width: 100%;
            height: 100%;
            padding-top: 60px;
            box-sizing: border-box;
        }
    </style>
</head>
<body>

    <div id="header">
        <h1>Our Family History</h1>
    </div>

    <div id="tree"></div>

    <script>
        // Define your family data array here
        // id: unique number for the person
        // pids: partner/spouse ID array
        // mid: mother's ID
        // fid: father's ID
        const familyData = [
            // Generation 1: Grandparents
            { id: 1, name: "Grandfather", gender: "male", img: "https://cdn.balkan.app/shared/m60/1.jpg" },
            { id: 2, name: "Grandmother", gender: "female", pids: [1], img: "https://cdn.balkan.app/shared/w60/1.jpg" },

            // Generation 2: Parents & Aunts/Uncles
            { id: 3, name: "Father", gender: "male", fid: 1, mid: 2, img: "https://cdn.balkan.app/shared/m30/1.jpg" },
            { id: 4, name: "Mother", gender: "female", pids: [3], img: "https://cdn.balkan.app/shared/w30/1.jpg" },

            // Generation 3: Siblings & Self
            { id: 5, name: "Abel", gender: "male", fid: 3, mid: 4, img: "https://cdn.balkan.app/shared/m10/1.jpg" },
            { id: 6, name: "Brother", gender: "male", fid: 3, mid: 4, img: "https://cdn.balkan.app/shared/m10/2.jpg" },
            { id: 7, name: "Sister", gender: "female", fid: 3, mid: 4, img: "https://cdn.balkan.app/shared/w10/1.jpg" },

            // Generation 4: Next Gen (Connects to parents via fid/mid)
            { id: 8, name: "Son", gender: "male", fid: 5, img: "https://cdn.balkan.app/shared/m10/3.jpg" },
            { id: 9, name: "Daughter 1", gender: "female", fid: 5, img: "https://cdn.balkan.app/shared/w10/2.jpg" },
            { id: 10, name: "Daughter 2", gender: "female", fid: 5, img: "https://cdn.balkan.app/shared/w10/3.jpg" }
        ];

        // Initialize and render the tree structure
        const tree = new FamilyTree(document.getElementById("tree"), {
            nodes: familyData,
            nodeBinding: {
                field_0: "name",
                img_0: "img"
            },
            template: "tomorrow" // Clean modern template style
        });
    </script>
</body>
</html>
